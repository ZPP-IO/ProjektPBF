@model IEnumerable<ProjectPBF.Models.CharacterModel>

@{
    ViewData["Title"] = "Lista Postaci";
}

<h1>Lista Postaci</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Stwórz nową postać</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Awatar
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Strength)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Agility)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Intelligence)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsAccepted)
            </th>
            <th>
                Właściciel
            </th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @if (!string.IsNullOrEmpty(item.AvatarUrl))
                    {
                        <img src="@item.AvatarUrl" alt="Postać" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                    }
                    else
                    {
                        <div style="width: 60px; height: 60px; background-color: #f0f0f0; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #aaa; font-size: 10px;">Brak</div>
                    }
                </td>
                <td>
                    <strong>@Html.DisplayFor(modelItem => item.Name)</strong>
                </td>
                <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Strength)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Agility)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Intelligence)
                </td>
                <td>
                    @if (item.IsAccepted)
                    {
                        <span class="badge bg-success">Zatwierdzona</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Oczekuje</span>
                    }
                </td>
                <td>
                    @* Wyświetlamy Nick zamiast ID *@
                    @(item.User?.Nick ?? "Nieznany")
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>